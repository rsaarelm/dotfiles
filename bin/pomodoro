#!/usr/bin/env python3

from collections.abc import Iterator
import os
import re
import sys
import subprocess
import time

LOG_FILE = os.path.expanduser("~/.local/share/pomodoro.timedot")

COMMAND = "mpv --really-quiet --input-terminal=no %s" % os.path.expanduser("~/Music/pomodoro.ogg")

# It's assumed that ~/Music/pomodoro.ogg is exactly this length. Lots of
# timedot code has a baked-in assumption that a Pomodor lasts half an hour so
# if you want to change this you need to edit the code as well as change the
# sound track and the constant.
DURATION_MIN = 32

DATE_LINE_RE = re.compile(r"^(\d{4}-\d{2}-\d{2})\s*$")

# (task_name, dots)
TASK_RE = re.compile(r"^(\D\S*)(\s\s+[. ]+)?$")

def run() -> bool:
    """Run the OS command to play the pomodoro, while blocking.

    Detect Ctrl-C from the user to stop early, return False if stopped early.
    """
    try:
        subprocess.run(COMMAND.split())
        return True
    except KeyboardInterrupt:
        return False


class TimeDotFile:
    """Wrapper for hledger timedot files.

    File contains lines like:
        2019-01-08
        fos.hledger.sup          .
        adm.email                ..
        adm.finance              .... .... ..
        ; Random comment line, needs to be preserved

    A date stamp with nothing else on the line indicates date for the lines below it
    A line with a whitespace-separated task name followed by dots is a task entry.
    There can be other lines like blanks and comments that should be preserved as is.

    The object loads its contents from a file (empty if file doesn't exist yet), and will save changes back when closed.
    """

    def __init__(self, path: str):
        self.path = path
        self.lines: list[str] = []
        self.last_date: str | None = None
        ## Lines for latest day's tasks.
        self.task_lines: dict[str, int] = {}
        self.changed = False
        self.today = time.strftime("%Y-%m-%d")

    def __enter__(self) -> "TimeDotFile":
        try:
            self.lines = []
            with open(self.path, "r") as f:
                for i, line in enumerate(f.read().splitlines()):
                    if DATE_LINE_RE.match(line):
                        self.last_date = DATE_LINE_RE.match(line).group(1)
                        # Reset task lines, we're only interested in the latest date's tasks.
                        self.task_lines = {}
                    # Store lines where a named task occurs, we may want to append to them.
                    if TASK_RE.match(line):
                        task_name = TASK_RE.match(line).group(1)
                        dots = TASK_RE.match(line).group(2) or ""
                        self.task_lines[task_name] = i
                    self.lines.append(line)

            # Don't cache tasks from before today.
            if self.last_date != self.today:
                self.task_lines = {}
        except FileNotFoundError:
            pass
        return self

    def __exit__(self, exc_type, exc_value, traceback) -> None:
        # Only write if you have something new.
        if not self.changed:
            return

        with open(self.path, "w") as f:
            f.write("\n".join(self.lines) + "\n")


    def record(self, task, num_dots=2):
        """Record a task with the current date and given number of dots.
        One dot is 15 minutes, so 2 dots is our default pomodoro.

        If the last date line is not for today, add a new date line.
        """
        if self.last_date != self.today:
            if len(self.lines) > 0 and self.lines[-1].strip() != "":
                self.lines.append("")
            self.lines.append(self.today)
            self.task_lines = {}
            self.changed = True

        if task not in self.task_lines:
            # Pad task name to 24 characters
            self.lines.append(task.ljust(22) + "  ")
            self.task_lines[task] = len(self.lines) - 1

        line_num = self.task_lines[task]
        line = self.lines[line_num]
        count = (TASK_RE.match(line).group(2) or "").count('.')

        for i in range(count, count + num_dots):
            # Add a space after every four dots.
            if i > 0 and i % 4 == 0:
                line += " "
            line += "."
        self.lines[line_num] = line

        self.changed = True


    def todays_stats(self) -> Iterator[tuple[str, int]]:
        """Return a dict of task name to number of dots for today."""
        for (task, line) in self.task_lines.items():
            line = self.lines[line]
            count = (TASK_RE.match(line).group(2) or "").count('.')
            yield (task, count)


def tformat(seconds: int) -> str:
    hours, rem = divmod(seconds, 3600)
    minutes, secs = divmod(rem, 60)

    parts = []

    if hours:
        parts.append(f"{hours} h")
    if minutes:
        parts.append(f"{minutes} min")
    if secs and not hours:
        parts.append(f"{secs} s")

    return " ".join(parts) or "0 s"



def main():
    # Usage
    # pomodoro.py [task_name]  - Run pomodoro and record to named task.
    # pomodoro.py              - Run pomodoro withour recording task.

    end_time = round(time.time() / 60.0 + DURATION_MIN) * 60
    end_str = time.strftime("%Y-%m-%d %a %H:%M", time.localtime(end_time))

    if len(sys.argv) > 1:
        task_name = sys.argv[1]
        # If task_mame doesn't match TASK_RE, raise an error
        if not TASK_RE.match(task_name):
            print("Invalid task name '%s'" % task_name)
            sys.exit(1)
        with TimeDotFile(LOG_FILE) as log:
            stats = dict(log.todays_stats())
            total_time = sum(stats.values()) * 900 + 1800
            task_time = stats.get(task_name, 0) * 900 + 1800
            if total_time > task_time:
                print(f"Working towards {tformat(task_time)} on '{task_name}' ({tformat(total_time)} total) until {end_str}.")
            else:
                print(f"Working towards {tformat(task_time)} on '{task_name}' until {end_str}.")

        if run():
            with TimeDotFile(LOG_FILE) as log:
                log.record(task_name)
        else:
            print("Pomodoro aborted.")
            return 1
    else:
        print(f"Running pomodoro until {end_str}.")
        if not run():
            return 1


if __name__ == "__main__":
    exit(main())
