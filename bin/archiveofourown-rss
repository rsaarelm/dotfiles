#!/usr/bin/env python3

# Usage: archiveofourown-rss ID [TITLE]
# eg. archiveofourown-rss 11478249 "Worth the Candle"
# Generates a RSS feed URL for that story ID.

import sys
import urllib.parse

def feedlify(feed_url):
    return f"https://feedly.com/i/subscription/content/feed%2F{urllib.parse.quote(feed_url, safe='')}"

def main():
    if len(sys.argv) < 2:
        print("Usage: archiveofourown-rss ID [TITLE]")
        sys.exit(1)

    story_id = sys.argv[1]
    title = sys.argv[2] if len(sys.argv) > 2 else f"Story {story_id}"

    base_url = "http://createfeed.wprssaggregator.com/extract.php"
    story_url = f"https://archiveofourown.org/works/{story_id}/navigate"
    feed_url = f"{base_url}?url={urllib.parse.quote(story_url)}&in_id_or_class=&url_contains=%2Fchapters%2F&order=reverse&feed_title={urllib.parse.quote(title)}"

    print(f"Feed URL for '{title}': {feed_url}")
    print(f"Feedly URL for '{title}': {feedlify(feed_url)}")

if __name__ == "__main__":
    main()
